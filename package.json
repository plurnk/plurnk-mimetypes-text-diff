{
    "name": "@plurnk/plurnk-mimetypes-text-diff",
    "version": "0.1.5",
    "description": "text/x-diff (unified/combined diff) mimetype handler for plurnk-service. Hand-rolled line-budget scanner; no parser dependency.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=26"
    },
    "plurnk": {
        "kind": "mimetype",
        "handlers": [
            {
                "name": "text/x-diff",
                "glyph": "🔀",
                "extensions": [
                    ".diff",
                    ".patch"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build && (git config core.hooksPath .githooks || true)",
        "deps:fresh": "npm outdated",
        "prepublishOnly": "npm run deps:fresh && npm audit --audit-level=moderate && npm test"
    },
    "devDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.18.0",
        "@types/node": "^26.0.0",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.16.0 || ^0.17.0 || ^0.18.0"
    }
}
